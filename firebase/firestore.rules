rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Usuarios: cada usuario solo su documento
    match /usuarios/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Clientes multiusuario
    match /clientes/{clienteId} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // Envíos multiusuario
    match /envios/{envioId} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // Denegar cualquier otro acceso
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
